{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-dx11",
            "type": "shell",
            "command": "${workspaceFolder}\\build_dx11.bat",
            "args": [
                "/Z7",
                "/EHsc",
                "@${workspaceFolder}/build_dx11.rsp",
                "/Fo:${workspaceFolder}\\bin\\",
                "/Fe:${workspaceFolder}\\bin\\sandbox.exe",
                "${workspaceFolder}\\source\\*.cpp",
                "/link",
                "/PDB:${workspaceFolder}\\bin\\sandbox.pdb"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "build-dx12",
            "type": "shell",
            "command": "${workspaceFolder}\\build_dx12.bat",
            "args": [
                "/Z7",
                "/EHsc",
                "/MDd",
                "@${workspaceFolder}/build_dx12.rsp",
                "/Fo:${workspaceFolder}\\bin\\",
                "/Fe:${workspaceFolder}\\bin\\sandbox.exe",
                "${workspaceFolder}\\source\\*.cpp",
                "/link",
                "/PDB:${workspaceFolder}\\bin\\sandbox.pdb"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        }
    ]
}